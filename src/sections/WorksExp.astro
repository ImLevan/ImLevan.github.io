---
import Briefcase from "../components/icons/Briefcase.astro";
import WorksExpItem from "../components/WorkExpItem.astro";
const EXPERIENCIE = [
    {
        date: "Mayo 2024 - Actualmente...",
        title: "Desarrollador full stack",
        company: "Boreal Technologies",
        description: `<p>Desarrollador de software con experiencia en el diseño y desarrollo de aplicaciones web utilizando tecnologías como Node.js, Spring Boot, Django, React y Angular.
        En mi rol actual, contribuyo al desarrollo de microservicios, la integración de API Rest y el despliegue en Azure Devops. Además, trabajo utilizando herramientas como JIRA, GIT y GitHub.</p>
        <p><a href="https://ar.linkedin.com/in/valentin-chianese" target="_blank" rel="noopener noreferrer"><i class="fa fa-linkedin"></i> Ver más detalles</a></p>`,
    },
    {
        date: "Diciembre 2020 - Mayo 2024",
        title: "Software Developer",
        company: "Autónomo",
        description: `<p>Desarrollador de aplicaciones de escritorio y app webs autónomo, dispuesto a ofrecer soluciones tecnológicas personalizadas.
        Desarrollo de herramientas a medida para la gestión de inventarios, control de ventas y administración de recursos, que optimizan procesos y mejoran la eficiencia operativa.</p>
        <p><a href="https://ar.linkedin.com/in/valentin-chianese" target="_blank" rel="noopener noreferrer"><i class="fa fa-linkedin"></i> Ver más detalles</a></p>`,
    },
];
---

<div id="work-exp">
    <div class="container">
        <header class="section-header">
            <h2>
                <Briefcase class="size-8" />
                Experiencia laboral
            </h2>
        </header>
        <ol class="experience-list">
            {
                EXPERIENCIE.map((experiencie) => (
                    <li>
                        <WorksExpItem {...experiencie} />
                    </li>
                ))
            }
        </ol>
    </div>
</div>

<style>
    #work-exp {
        max-width: 1100px;
        margin: auto;
        margin-bottom: 6rem;
        padding-top: 0px;
    }

    .experience-list {
        position: relative;
        margin: 3rem 0;
    }
</style>
