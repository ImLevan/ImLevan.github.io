---
import Proyecto from "../components/Proyecto.astro";
import { allProjects } from "../utilities/projects";
---

<div class="portfolio" id="portfolio">
    <div class="container">
        <header class="section-header">
            <h3 class="section-title">Proyectos</h3>
            <p>
                Visualizá los proyectos en los que estuve trabajando y
                voy a seguir actualizándolos, alguno más ambicioso que otro.
                Espero que te parezcan interesantes.
            </p>
        </header>

        <div class="row">
            <div class="col-lg-12">
                <ul id="portfolio-flters">
                    <li data-filter="*" class="filter-active">Todos</li>
                    <li data-filter="web-dev">Desarrollo web</li>
                    <li data-filter="app-dev">Desarrollo de aplicaciones</li>
                </ul>
            </div>
        </div>
        <section id="portfolio">
            <div class="portfolio-layout">
                <div class="portfolio-featured">
                    {
                        allProjects.map((project: any, index: number) => (
                            <div class="featured-project" data-index={index}>
                                <Proyecto project={project} featured={true} />
                            </div>
                        ))
                    }
                </div>
                <div class="portfolio-list">
                    {
                        allProjects.map((project: any, index: number) => (
                            <div
                                class={`portfolio-list-item ${project.projectClass}`}
                                data-index={index}
                            >
                                <div class="list-item-img">
                                    <img
                                        src={`/img/portfolio/${project.projectImage}`}
                                        alt={project.projectTitle}
                                        loading="lazy"
                                    />
                                </div>
                                <div class="list-item-info">
                                    <h4>{project.projectTitle}</h4>
                                    <span class="list-item-badge">
                                        {project.projectClass === "web-dev"
                                            ? "Desarrollo web"
                                            : "App"}
                                    </span>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
            <div class="mensaje-sin-proyectos" style="display: none;">
                No hay proyectos disponibles en esta categoría.
            </div>
        </section>
    </div>
</div>

<style>
    .portfolio {
        position: relative;
        clear: both;
        padding: 60px 0 30px 0;
    }

    .portfolio .section-header p {
        margin-bottom: 30px;
    }

    .portfolio #portfolio-flters {
        padding: 0;
        margin: -15px 0 30px 0;
        list-style: none;
        text-align: center;
    }

    .portfolio #portfolio-flters li {
        cursor: pointer;
        margin: 15px -3px 5px -3px;
        display: inline-block;
        padding: 10px 15px;
        color: var(--color_dominante);
        font-size: 14px;
        line-height: 15px;
        text-transform: uppercase;
        border: 1px solid var(--color_dominante);
        background: #ffffff;
        transition: all 0.3s ease-in-out;
    }

    .portfolio #portfolio-flters li:hover,
    .portfolio #portfolio-flters li.filter-active {
        background: var(--color_dominante);
        color: #ffffff;
    }

    .portfolio #portfolio-flters li:last-child {
        margin-right: 0;
    }

    #portfolio {
        max-width: 1100px;
        padding: 0;
        margin: auto;
    }

    #portfolio .titulo-seccion {
        text-align: center;
        font-size: 22px;
        text-transform: uppercase;
        color: #ff5080;
        text-decoration: underline;
        text-decoration-color: #d3d3d3;
        text-decoration-thickness: 5px;
        margin-bottom: 30px;
    }

    .portfolio-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
        position: relative;
    }

    .portfolio-featured {
        flex: 1;
        min-width: 0;
        padding-right: 364px;
    }

    .featured-project {
        display: none;
    }

    .featured-project.active {
        display: block;
    }

    .featured-project.active .imagen-proyecto img {
        width: 100%;
        height: auto;
        display: block;
    }

    .portfolio-list {
        position: absolute;
        top: 0;
        bottom: 0;
        right: 0;
        width: 340px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding-right: 4px;
    }

    .portfolio-list::-webkit-scrollbar {
        width: 6px;
    }

    .portfolio-list::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 3px;
    }

    .portfolio-list::-webkit-scrollbar-thumb {
        background: var(--color_dominante);
        border-radius: 3px;
    }

    .portfolio-list-item {
        display: flex;
        gap: 12px;
        padding: 10px;
        cursor: pointer;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        transition: background 0.3s, border-color 0.3s;
        align-items: center;
        border-left: 3px solid transparent;
        border-radius: 4px;
    }

    .portfolio-list-item:hover {
        background: rgba(116, 11, 55, 0.15);
    }

    .portfolio-list-item.active {
        background: rgba(116, 11, 55, 0.25);
        border-left-color: var(--color_dominante);
    }

    .list-item-img {
        width: 80px;
        height: 56px;
        flex-shrink: 0;
        overflow: hidden;
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .list-item-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }

    .portfolio-list-item:hover .list-item-img img {
        transform: scale(1.05);
    }

    .list-item-info {
        flex: 1;
        min-width: 0;
    }

    .list-item-info h4 {
        font-size: 14px;
        margin: 0 0 4px 0;
        color: #ffffff;
        font-weight: 600;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .list-item-badge {
        font-size: 11px;
        color: var(--color_dominante);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    @media screen and (max-width: 991px) {
        #portfolio {
            padding: 50px 0;
        }

        .portfolio-layout {
            flex-direction: column;
            gap: 20px;
            position: static;
        }

        .portfolio-featured {
            padding-right: 0;
        }

        .portfolio-list {
            position: static;
            width: 100%;
            flex-direction: row;
            overflow-x: auto;
            overflow-y: hidden;
            padding-right: 0;
            padding-bottom: 8px;
            gap: 10px;
        }

        .portfolio-list-item {
            flex-shrink: 0;
            width: 240px;
            flex-direction: column;
            align-items: flex-start;
            border-left: none;
            border-bottom: 2px solid transparent;
            padding: 8px;
        }

        .portfolio-list-item.active {
            border-left-color: transparent;
            border-bottom-color: var(--color_dominante);
        }

        .list-item-img {
            width: 100%;
            height: 100px;
        }
    }

    @media screen and (max-width: 767px) {
        #portfolio {
            padding: 50px 0;
        }

        .portfolio-list-item {
            width: 200px;
        }

        .list-item-img {
            height: 80px;
        }

        .list-item-info h4 {
            font-size: 12px;
        }
    }

    @media screen and (max-width: 575px) {
        .portfolio-list {
            gap: 8px;
        }

        .portfolio-list-item {
            width: 160px;
            padding: 6px;
        }

        .list-item-img {
            height: 70px;
        }

        .list-item-info h4 {
            font-size: 11px;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const filterItems = document.querySelectorAll("#portfolio-flters li");
        const featuredProjects =
            document.querySelectorAll(".featured-project");
        const listItems = document.querySelectorAll(".portfolio-list-item");
        let selectedIndex = 0;

        function getProjectCategory(index) {
            const proyecto = featuredProjects[index].querySelector(".proyecto");
            const classes = Array.from(proyecto.classList);
            return classes.find((c) => c === "web-dev" || c === "app-dev") || "";
        }

        function isVisible(index, category) {
            return category === "*" || getProjectCategory(index) === category;
        }

        function selectProject(index) {
            featuredProjects[selectedIndex].classList.remove("active");
            listItems[selectedIndex].classList.remove("active");

            selectedIndex = index;

            featuredProjects[selectedIndex].classList.add("active");
            listItems[selectedIndex].classList.add("active");

            listItems[selectedIndex].scrollIntoView({
                block: "nearest",
                behavior: "smooth",
            });
        }

        function applyFilter(category) {
            let firstVisible = -1;

            featuredProjects.forEach((fp, i) => {
                const visible = isVisible(i, category);
                listItems[i].style.display = visible ? "" : "none";

                if (visible && firstVisible === -1) {
                    firstVisible = i;
                }
            });

            if (!isVisible(selectedIndex, category)) {
                if (firstVisible !== -1) {
                    selectProject(firstVisible);
                } else {
                    featuredProjects[selectedIndex].classList.remove("active");
                }
            } else {
                featuredProjects.forEach((fp, i) => {
                    fp.classList.toggle("active", i === selectedIndex);
                });
            }

            const mensajeSinProyectos = document.querySelector(
                ".mensaje-sin-proyectos",
            );
            mensajeSinProyectos.style.display =
                firstVisible === -1 ? "block" : "none";
        }

        applyFilter("*");

        filterItems.forEach((item) => {
            item.addEventListener("click", function () {
                filterItems.forEach((i) => i.classList.remove("filter-active"));
                this.classList.add("filter-active");
                applyFilter(this.getAttribute("data-filter"));
            });
        });

        listItems.forEach((item) => {
            item.addEventListener("click", function () {
                const index = parseInt(this.dataset.index);
                if (
                    index !== selectedIndex &&
                    listItems[index].style.display !== "none"
                ) {
                    selectProject(index);
                }
            });
        });
    });
</script>
